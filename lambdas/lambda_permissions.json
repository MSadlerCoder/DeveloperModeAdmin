{
  "managed_policy_arns": [
    "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
  ],
  "statements": [
    {
      "Sid": "TaskAndProjectBucketListAccess",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::developer-mode"
    },
    {
      "Sid": "TaskObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::developer-mode/tasks/*"
    },
    {
      "Sid": "ProjectObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::developer-mode/projects/*"
    },
    {
      "Sid": "TaskQueueSendMessage",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage"
      ],
      "Resource": "arn:aws:sqs:eu-north-1:439647920559:KapitanDesign_Tasks"
    },
    {
      "Sid": "TaskMessageQueueSendMessage",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage"
      ],
      "Resource": "arn:aws:sqs:eu-north-1:439647920559:KapitanDesign_Messages"
    },
    {
      "Sid": "TaskMessageQueueConsume",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:ChangeMessageVisibility"
      ],
      "Resource": "arn:aws:sqs:eu-north-1:439647920559:KapitanDesign_Messages"
    },
    {
      "Sid": "TaskChatBedrockInvoke",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CodexTaskQueueSendMessage",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage"
      ],
      "Resource": "arn:aws:sqs:eu-north-1:439647920559:KapitanDesign_CodexTask"
    }
  ]
}
